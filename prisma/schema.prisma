  // The meat
  steps        Json     // ordered array of { order, title, description, tips? }
  qualityCriteria Json  // { good: string[], bad: string[], checkBefore: string[] }
  examples     Json?    // { good: string[], bad: string[] } — optional

  // Meta
  status       String   @default("active") // active | draft | archived
  version      Int      @default(1)
  createdBy    String?  @db.Text // user UUID or agent name
  lastUpdatedBy String? @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  // Ownership
  ownerAgent        String?  @db.Text  // primary agent responsible for this skill
  maintainerAgents  String[]           // other agents who maintain it

  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks          Task[]              @relation("TaskSkill")
  knowledgeLinks AgentKnowledgeLink[]
  evaluations    SkillEvaluation[]

  @@index([workspaceId])
  @@index([category])
  @@index([status])
  @@index([tags])
  @@index([ownerAgent])
  @@map("skills")
}

// ==================== SKILL EVALUATIONS ====================

model SkillEvaluation {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String   @db.Text
  skillId     String   @db.Text
  taskId      String?  @db.Text   // task this evaluation came from
  skillVersion Int                // version of the skill that was evaluated

  // Who evaluated
  agentId     String   @db.Text   // "harvey" | "doug" | "theo" | "casper"
  agentSkillRole String @default("incidental-user") // owner | regular-user | incidental-user

  // Outcome
  qualityScore  String            // met | partial | not_met
  confidence    String @default("medium") // low | medium | high

  // Notes
  strengthNotes   String?  @db.Text  // what worked well
  gapNotes        String?  @db.Text  // what was unclear/missing/wrong
  deviationNotes  String?  @db.Text  // did they deviate from steps, and why

  // Suggestion trigger
  suggestUpdate   Boolean  @default(false)
  suggestionId    String?  @db.Text  // if a suggestion was created from this

  createdAt DateTime @default(now()) @db.Timestamptz()

  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([workspaceId])
  @@index([agentId])
  @@index([taskId])
  @@index([qualityScore])
  @@map("skill_evaluations")
}

// ==================== MEETINGS ====================

model Meeting {
  id                   String    @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId          String    @db.Text

  title                String
  agenda               String    @db.Text  // markdown

  status               String    @default("draft")
  // draft | open | contributing | concluded | archived

  // Participants — required must contribute before conclusion; optional are invited but non-blocking
  requiredParticipants String[]  // ["harvey", "doug", "theo", "casper", "ben"]
  optionalParticipants String[]  @default([])

  // Skills agents should use when preparing contributions (skill IDs)
  requiredSkills       String[]  @default([])

  // Structured conclusion (written by Ben or agent)
  conclusion           Json?
  // {
  //   decision: string,
  //   rationale: string,
  //   resultingActions: [{ title, assignTo, dueDate? }],
  //   owners: string[],
  //   reviewDate?: string
  // }

  // Who concluded — split into type + value for clean querying
  concludedByType      String?   @db.Text  // "user" | "agent"
  concludedBy          String?   @db.Text  // user UUID or agent name
  concludedAt          DateTime? @db.Timestamptz()

  // Who created — typed for clean querying
  createdByType        String    @db.Text  // "user" | "agent"
  createdBy            String    @db.Text  // user UUID or agent name

  createdAt            DateTime  @default(now()) @db.Timestamptz()
  updatedAt            DateTime  @updatedAt @db.Timestamptz()

  workspace            Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contributions        MeetingContribution[]

  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
  @@map("meetings")
}

model MeetingContribution {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  meetingId   String   @db.Text

  author      String   @db.Text
  // "harvey" | "theo" | "doug" | "casper" | "ben"

  role        String   @db.Text
  // "strategic-commercial" | "research-planning" | "technical-systems" | "ops-execution" | "founder"

  position       String   @db.Text   // 1–2 sentence headline stance
  reasoning      String   @db.Text   // full explanation
  recommendation String   @db.Text   // what they think should happen
  confidence     Int                  // 1–5

  // Enum-backed allowlist: blocker | risk | opportunity | dependency
  flags          String[]  @default([])

  // Skill IDs used to inform this contribution (validated against skills table)
  skillsUsed     String[]  @default([])

  // Structured evidence refs:
  // [{ type: "document"|"task"|"objective"|"memory"|"insight"|"url", id?: string, url?: string, label?: string }]
  evidenceRefs   Json      @default("[]")

  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()

  meeting        Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([author])
  @@map("meeting_contributions")
}

// ==================== TASKBOX ====================

model TaskboxBoard {
  id              String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId     String   @db.Text
  name            String
  description     String?  @db.Text
  columns         Json     @default("[\"todo\", \"in_progress\", \"done\"]")
  automationRules Json?
  createdBy       String   @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks           TaskboxTask[]
  automationLogs  TaskboxAutomationLog[]

  @@index([workspaceId])
  @@map("taskbox_boards")
}

model TaskboxTask {
  id                String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId       String   @db.Text
  boardId           String?  @db.Text
  companyId         String?  @db.Text
  projectId         String?  @db.Text

  title             String
  description       String?  @db.Text
  status            String   @default("todo")
  priority          Int      @default(3)

  assignedTo        String?  @db.Uuid
  createdBy         String   @db.Uuid

  dueAt             DateTime? @db.Timestamptz()
  blockedReason     String?   @db.Text
  blockedAt         DateTime? @db.Timestamptz()

  automationEnabled Boolean  @default(false)
  automationRules   Json?

  tags              String[]
  labels            String[]
  position          Int?

  createdAt         DateTime  @default(now()) @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @db.Timestamptz()
  completedAt       DateTime? @db.Timestamptz()

  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board             TaskboxBoard?         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  automationLogs    TaskboxAutomationLog[]

  @@index([workspaceId])
  @@index([boardId])
  @@index([status])
  @@index([assignedTo])
  @@index([dueAt])
  @@index([companyId])
  @@index([projectId])
  @@map("taskbox_tasks")
}

model TaskboxAutomationLog {
  id           String    @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  taskId       String?   @db.Text
  boardId      String?   @db.Text
  triggerType  String
  actionType   String
  triggeredAt  DateTime  @default(now()) @db.Timestamptz()
  executedAt   DateTime? @db.Timestamptz()
  status       String    @default("pending")
  errorMessage String?   @db.Text
  metadata     Json?

  task         TaskboxTask?  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  board        TaskboxBoard? @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([boardId])
  @@index([status])
  @@index([triggeredAt])
  @@map("taskbox_automation_logs")
}

// ==================== AGENT PROFILES ====================

model Agent {
  id                   String   @id @db.Text // "harvey" | "doug" | "theo" | "casper"
  workspaceId          String   @db.Text
  name                 String
  role                 String   @default("")
  perspective          String   @default("") // e.g. "Strategic / Commercial"
  tagline              String   @default("") // one-liner
  identity             String   @default("") @db.Text // markdown — who they are
  toneOfVoice          String   @default("") @db.Text
  workingStyle         String   @default("") @db.Text
  coreResponsibilities String   @default("") @db.Text
  escalationRules      String   @default("") @db.Text
  decisionScope        String   @default("") @db.Text
  approvalBoundaries   String   @default("") @db.Text
  avatar               String?  @db.Text // emoji or image URL
  status               String   @default("active") // active | paused | offline
  profileVersion       Int      @default(1)
  createdAt            DateTime @default(now()) @db.Timestamptz()
  updatedAt            DateTime @updatedAt @db.Timestamptz()

  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeLinks AgentKnowledgeLink[]

  @@unique([workspaceId, id])
  @@index([workspaceId])
  @@map("agents")
}

model AgentKnowledgeLink {
  id         String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  agentId    String   @db.Text
  workspaceId String  @db.Text
  linkType   String   // skill | document | briefing | url | file
  title      String
  skillId    String?  @db.Text
  documentId String?  @db.Text
  url        String?  @db.Text
  notes      String?  @db.Text
  required   Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz()

  agent    Agent     @relation(fields: [agentId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  skill    Skill?    @relation(fields: [skillId], references: [id], onDelete: SetNull)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([workspaceId])
  @@map("agent_knowledge_links")
}

// ==================== RELAY CALL LOG ====================

model RelayCall {
  id           String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  actor        String   @db.Text                // "doug" | "harvey" | "theo" | "casper"
  method       String   @db.Text                // GET | POST | PATCH | PUT | DELETE
  path         String   @db.Text                // e.g. /api/tasks/direct
  statusCode   Int      @map("status_code")
  latencyMs    Int      @map("latency_ms")
  requestSize  Int      @default(0) @map("request_size")   // bytes
  responseSize Int      @default(0) @map("response_size")  // bytes
  success      Boolean
  errorCode    String?  @db.Text @map("error_code")        // structured error code if failed
  calledAt     DateTime @default(now()) @db.Timestamptz() @map("called_at")

  @@index([actor])
  @@index([calledAt])
  @@index([path])
  @@map("relay_calls")
}

