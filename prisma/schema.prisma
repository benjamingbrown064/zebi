// ==================== BRAIN DUMP (Phase 1) ====================

model BrainDumpSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String   @db.Text
  userId      String   @db.Uuid
  audioUrl    String?
  
  transcriptRaw   String?  @db.Text
  transcriptClean String?  @db.Text
  summary         String?  @db.Text
  
  status String @default("recorded") // recorded | transcribed | processed | awaiting_review | approved | partially_applied | applied | failed
  
  processingStartedAt   DateTime? @db.Timestamptz()
  processingCompletedAt DateTime? @db.Timestamptz()
  
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
  
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  entityMentions   BrainDumpEntityMention[]
  proposedActions  BrainDumpProposedAction[]
  resolutionIssues BrainDumpResolutionIssue[]
  executionLogs    BrainDumpExecutionLog[]
  
  @@index([workspaceId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("brain_dump_sessions")
}

model BrainDumpEntityMention {
  id                  String  @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  brainDumpSessionId  String  @db.Text
  mentionText         String
  mentionType         String // company | goal | objective | project | task | person | date | status | priority | note
  
  transcriptOffsetStart Int?
  transcriptOffsetEnd   Int?
  
  resolutionStatus String @default("unmatched") // matched | ambiguous | unmatched
  matchedEntityId  String? @db.Text
  matchedEntityType String?
  confidence       Decimal @default(0) @db.Decimal(3, 2)
  
  brainDumpSession BrainDumpSession @relation(fields: [brainDumpSessionId], references: [id], onDelete: Cascade)
  
  @@index([brainDumpSessionId])
  @@index([resolutionStatus])
  @@map("brain_dump_entity_mentions")
}

model BrainDumpProposedAction {
  id                  String  @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  brainDumpSessionId  String  @db.Text
  actionType          String // create_goal | update_goal | create_company | update_company | create_objective | update_objective | create_project | update_project | create_task | update_task | assign_task | set_due_date | set_priority | set_status | add_note | link_entity
  targetEntityType    String
  targetEntityId      String? @db.Text
  
  payloadJson         Json
  
  confidenceScore  Decimal @db.Decimal(3, 2)
  confidenceLevel  String // high | medium | low
  requiresConfirmation Boolean @default(false)
  
  status         String @default("proposed") // proposed | approved | edited | rejected | applied | failed
  reasonSummary  String? @db.Text
  
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
  
  brainDumpSession BrainDumpSession          @relation(fields: [brainDumpSessionId], references: [id], onDelete: Cascade)
  executionLogs    BrainDumpExecutionLog[]
  
  @@index([brainDumpSessionId])
  @@index([actionType])
  @@index([confidenceLevel])
  @@index([status])
  @@map("brain_dump_proposed_actions")
}

model BrainDumpResolutionIssue {
  id                  String  @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  brainDumpSessionId  String  @db.Text
  issueType           String // ambiguous_person | ambiguous_project | vague_date | unknown_entity | conflicting_instruction
  
  sourceText          String  @db.Text
  candidateMatchesJson Json?
  suggestedResolution String? @db.Text
  resolvedValue       String?
  
  resolutionStatus String @default("open") // open | resolved | skipped
  
  brainDumpSession BrainDumpSession @relation(fields: [brainDumpSessionId], references: [id], onDelete: Cascade)
  
  @@index([brainDumpSessionId])
  @@index([resolutionStatus])
  @@map("brain_dump_resolution_issues")
}

model BrainDumpExecutionLog {
  id                  String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  brainDumpSessionId  String   @db.Text
  proposedActionId    String   @db.Text
  
  executionStatus  String // success | failed | skipped
  executionMessage String? @db.Text
  
  resultingEntityId   String? @db.Text
  resultingEntityType String?
  
  createdAt DateTime @default(now()) @db.Timestamptz()
  
  brainDumpSession BrainDumpSession         @relation(fields: [brainDumpSessionId], references: [id], onDelete: Cascade)
  proposedAction   BrainDumpProposedAction  @relation(fields: [proposedActionId], references: [id], onDelete: Cascade)
  
  @@index([brainDumpSessionId])
  @@index([proposedActionId])
  @@index([executionStatus])
  @@map("brain_dump_execution_logs")
}

// ==================== VOICE-TO-TASK BREAKDOWN ====================

model TaskGenerationSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Text
  
  // Context (where tasks will be created)
  contextType String   @map("context_type") // project | objective | company | general
  contextId   String?  @map("context_id") @db.Uuid
  
  // Audio & Transcript
  audioUrl              String? @map("audio_url")
  audioDurationSeconds  Int?    @map("audio_duration_seconds")
  transcriptRaw         String? @map("transcript_raw") @db.Text
  transcriptClean       String? @map("transcript_clean") @db.Text
  
  // Status tracking
  status       String   @default("recording") // recording | processing | ready_for_review | applied | cancelled | failed
  errorMessage String?  @map("error_message") @db.Text
  
  // Results summary
  generatedTaskCount Int @default(0) @map("generated_task_count")
  createdTaskCount   Int @default(0) @map("created_task_count")
  skippedTaskCount   Int @default(0) @map("skipped_task_count")
  
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  processedAt DateTime? @map("processed_at") @db.Timestamptz()
  appliedAt   DateTime? @map("applied_at") @db.Timestamptz()
  
  // Relations
  workspace  Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  candidates GeneratedTaskCandidate[]
  results    TaskGenerationResult[]
  
  @@index([workspaceId])
  @@index([userId])
  @@index([status])
  @@index([contextType, contextId])
  @@map("task_generation_sessions")
}

model GeneratedTaskCandidate {
  id                       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskGenerationSessionId  String  @map("task_generation_session_id") @db.Uuid
  
  // Task content
  title       String
  description String? @db.Text
  
  // AI metadata
  confidenceScore      Decimal? @map("confidence_score") @db.Decimal(3, 2)
  duplicateStatus      String   @map("duplicate_status") @default("none") // none | possible_existing | possible_generated
  duplicateReferenceId String?  @map("duplicate_reference_id") @db.Uuid
  
  // User control
  selected  Boolean @default(true)
  sortOrder Int     @map("sort_order")
  
  // Extraction context
  sourceTextFragment String? @map("source_text_fragment") @db.Text
  
  // Optional extracted metadata (only if explicitly stated)
  suggestedAssigneeId String?   @map("suggested_assignee_id") @db.Uuid
  suggestedDueDate    DateTime? @map("suggested_due_date") @db.Date
  suggestedPriority   Int?      @map("suggested_priority")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  
  // Relations
  session TaskGenerationSession @relation(fields: [taskGenerationSessionId], references: [id], onDelete: Cascade)
  
  @@index([taskGenerationSessionId])
  @@index([selected])
  @@index([taskGenerationSessionId, sortOrder])
  @@map("generated_task_candidates")
}

model TaskGenerationResult {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskGenerationSessionId String   @map("task_generation_session_id") @db.Uuid
  
  // Result tracking
  createdTaskIds      String[] @default([]) @map("created_task_ids")
  skippedCandidateIds String[] @default([]) @map("skipped_candidate_ids")
  
  // Summary metadata
  resultSummary Json? @map("result_summary")
  
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  
  // Relations
  session TaskGenerationSession @relation(fields: [taskGenerationSessionId], references: [id], onDelete: Cascade)
  
  @@index([taskGenerationSessionId])
  @@map("task_generation_results")
}
