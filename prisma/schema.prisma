// Zebi - AI Business Operating System
// Updated schema with Objective Engine + Company Intelligence

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== WORKSPACES ====================

model Workspace {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  name      String
  plan      String   @default("free")
  ownerId   String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  // Founder Operating Mode
  operatingMode    String    @default("momentum") // pressure | plateau | momentum | drift
  modeSetBy        String    @default("auto")     // auto | manual
  modeUpdatedAt    DateTime? @db.Timestamptz()
  modeExpiresAt    DateTime? @db.Timestamptz()    // null = never expires (only set for manual overrides)
  modeSuggested    String?                        // AI-suggested mode (advisory only)
  modeSignals      Json?                          // Snapshot of signals used for detection

  // Existing Relations
  members      WorkspaceMember[]
  tasks        Task[]
  goals        Goal[]
  projects     Project[]
  tags         Tag[]
  statuses     Status[]
  savedFilters SavedFilter[]
  comments     TaskComment[]
  attachments  TaskAttachment[]
  activityLogs ActivityLog[]
  shareLinks   ShareLink[]

  // New Relations
  missions       Mission[]
  objectives     Objective[]
  spaces         Space[]
  documents      Document[]
  notes          Note[]
  aiMemories     AIMemory[]
  aiInsights     AIInsight[]
  files          File[]
  repeatingTasks RepeatingTask[]
  aiWorkQueue    AIWorkQueue[]

  // Multi-agent operating system
  handoffs          Handoff[]
  agentHeartbeats   AgentHeartbeat[]
  agentMessages     AgentMessage[]
  skills            Skill[]
  meetings          Meeting[]

  // AI Assistant Relations (Week 1 Day 1-2)
  aiConversations   AIConversation[]
  aiSuggestions     AISuggestion[]
  aiAssistantMemory AIAssistantMemory[]

  // Brain Dump Relations (Phase 1)
  brainDumpSessions BrainDumpSession[]

  // Voice-to-Task Relations
  taskGenerationSessions TaskGenerationSession[]

  // Inbox Relations (Phase 1)
  inboxItems InboxItem[]

  // Taskbox Relations
  taskboxBoards TaskboxBoard[]
  taskboxTasks  TaskboxTask[]

  // Agent Profile Relations
  agents             Agent[]

  // Skill Evolution Relations
  skillEvaluations   SkillEvaluation[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String   @db.Text
  userId      String   @db.Uuid
  role        String   @default("member") // owner, admin, member, guest
  createdAt   DateTime @default(now()) @db.Timestamptz()

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

// ==================== MISSION (NEW) ====================

model Mission {
  id             String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId    String   @db.Text
  statement      String
  revenueTarget  Decimal? @db.Decimal(15, 2)
  timeline       String?
  principles     Json?
  successMetrics Json?
  aiRules        Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()
  createdBy      String   @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goals     Goal[]

  @@index([workspaceId])
  @@index([isActive])
}

// ==================== COMPANIES (NEW) ====================

model Space {
  id            String  @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId   String  @db.Text
  name          String
  industry      String?
  stage         String?
  businessModel String?

  missionStatement    String?
  executiveSummary    String? @db.Text
  vision              String? @db.Text
  strategicObjectives Json?
  revenueTargets      Json?

  targetCustomers String? @db.Text
  marketSize      String?
  competitors     Json?
  differentiators Json?

  coreProduct String? @db.Text
  pricing     Json?
  features    Json?
  roadmap     Json?

  usps        Json?
  positioning String? @db.Text

  aiImprovementAreas Json?
  aiOpportunities    Json?

  logoUrl    String?
  websiteUrl String?
  revenue    Decimal?  @db.Decimal(15, 2)
  archivedAt DateTime? @db.Timestamptz()
  createdAt  DateTime  @default(now()) @db.Timestamptz()
  updatedAt  DateTime  @updatedAt @db.Timestamptz()
  createdBy  String    @db.Uuid

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  objectives     Objective[]
  projects       Project[]
  documents      Document[]
  notes          Note[]
  memories       AIMemory[]
  insights       AIInsight[]
  files          File[]
  tasks          Task[]
  repeatingTasks RepeatingTask[]

  @@map("Company")
  @@index([workspaceId])
  @@index([archivedAt])
}

// ==================== OBJECTIVES (NEW) ====================

model Objective {
  id          String  @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String  @db.Text
  companyId   String? @db.Text
  goalId      String? @db.Text

  title         String
  description   String? @db.Text
  objectiveType String

  metricType   String
  targetValue  Decimal @db.Decimal(15, 2)
  currentValue Decimal @default(0) @db.Decimal(15, 2)
  unit         String?

  startDate DateTime @db.Date()
  deadline  DateTime @db.Date()

  status          String    @default("active")
  progressPercent Decimal   @default(0) @db.Decimal(5, 2)
  lastChecked     DateTime? @db.Timestamptz()

  // Progress tracking (V2)
  progressMode        String    @default("auto") // "auto" | "manual"
  completedTaskCount  Int?
  totalTaskCount      Int?
  lastProgressRecalc  DateTime? @db.Timestamptz()
  scopeChangeNote     String?   @db.Text

  aiActionPlan   Json?
  blockerRules   Json?
  checkFrequency String @default("daily")

  priority  Int      @default(3)
  dependsOn String[]

  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  createdBy   String    @db.Uuid
  completedAt DateTime? @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Space?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  goal      Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)

  milestones      ObjectiveMilestone[]
  progressEntries ObjectiveProgress[]
  blockers        ObjectiveBlocker[]
  projects        Project[]
  tasks           Task[]
  notes           Note[]

  @@index([workspaceId])
  @@index([companyId])
  @@index([goalId])
  @@index([status])
  @@index([deadline])
  @@index([lastChecked])
  @@index([workspaceId, status])
  @@index([progressMode])
}

model ObjectiveMilestone {
  id          String    @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  objectiveId String    @db.Text
  title       String
  targetValue Decimal   @db.Decimal(15, 2)
  targetDate  DateTime  @db.Date()
  completedAt DateTime? @db.Timestamptz()
  status      String    @default("pending")

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
  @@index([targetDate])
}

model ObjectiveProgress {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  objectiveId String   @db.Text
  value       Decimal  @db.Decimal(15, 2)
  entryDate   DateTime @db.Date()
  note        String?
  source      String
  createdBy   String?  @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz()

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
  @@index([entryDate])
}

model ObjectiveBlocker {
  id           String    @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  objectiveId  String    @db.Text
  blockerType  String
  title        String
  description  String    @db.Text
  severity     String
  detectedAt   DateTime  @default(now()) @db.Timestamptz()
  resolvedAt   DateTime? @db.Timestamptz()
  aiSuggestion Json?

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
  @@index([resolvedAt])
}

// ==================== STATUSES ====================

model Status {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String   @db.Text
  name        String
  type        String
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([type])
}

// ==================== TASKS (ENHANCED) ====================

model Task {
  id            String    @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId   String    @db.Text
  title         String
  description   String?
  statusId      String    @db.Text
  priority      Int       @default(3)
  dueAt         DateTime? @db.Timestamptz()
  startAt       DateTime? @db.Timestamptz()
  completedAt   DateTime? @db.Timestamptz()
  archivedAt    DateTime? @db.Timestamptz()
  projectId     String?   @db.Text
  goalId        String?   @db.Text
  parentTaskId  String?   @db.Text
  sortOrder     Decimal   @default(0)
  effortPoints  Int?
  isMilestone   Boolean   @default(false)
  todayPinDate  DateTime? @db.Date()
  todayOrder    Int?
  todayCategory String?   @db.Text
  plannedDate   DateTime? @db.Date() // Weekly planner: day this task is planned for
  shareSlug     String?   @unique
  assigneeId    String?   @db.Uuid
  botAssignee   String?   @db.Text // "doug", "harvey", or null
  createdAt     DateTime  @default(now()) @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @db.Timestamptz()
  createdBy     String    @db.Uuid

  // NEW FIELDS
  companyId       String? @db.Text
  objectiveId     String? @db.Text
  repeatingTaskId String? @db.Text
  aiGenerated     Boolean @default(false)
  aiAgent         String?

  // Phase 2: Outcome tracking
  expectedOutcome  String?  @db.Text  // What this task should produce
  completionNote   String?  @db.Text  // What actually happened when completed
  outputUrl        String?  @db.Text  // Link to artefact/output

  // Multi-agent operating system fields
  ownerAgent       String?  @db.Text  // "harvey" | "theo" | "doug" | "casper"
  reviewerAgent    String?  @db.Text  // optional reviewer
  handoffToAgent   String?  @db.Text  // target agent for handoff
  requestedBy      String?  @db.Text  // "ben" | "harvey" | "theo" | "doug" | "casper" | "system"
  taskType         String?  @db.Text  // "strategy" | "research" | "build" | "ops" | "routine" | "admin" | "review" | "bug" | "briefing"
  decisionNeeded   Boolean  @default(false)
  decisionSummary  String?  @db.Text
  waitingOn        String?  @db.Text  // "ben" | "harvey" | "theo" | "doug" | "casper" | "external" | "none"
  blockedReason    String?  @db.Text
  definitionOfDone String?  @db.Text
  nextAction       String?  @db.Text
  dependencyIds    String[]
  outputDocId      String?  @db.Text  // primary output document id
  linkedDocIds     String[]              // additional referenced document ids
  skillId              String?  @db.Text  // skill/playbook used for this task
  skipEvaluation       Boolean? @default(false) // bypass evaluation gate
  skipEvaluationReason String?  @db.Text  // required if skipEvaluation is true

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  status     Status    @relation(fields: [statusId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  goal       Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  parentTask Task?     @relation("ParentChild", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks   Task[]    @relation("ParentChild")

  // NEW RELATIONS
  company       Space?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  objective     Objective?   @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  skill         Skill?       @relation("TaskSkill", fields: [skillId], references: [id], onDelete: SetNull)
  repeatingTask RepeatingTask? @relation(fields: [repeatingTaskId], references: [id], onDelete: SetNull)
  files         File[]

  tags         TaskTag[]
  comments     TaskComment[]
  attachments  TaskAttachment[]
  activityLogs ActivityLog[]
  notes        Note[]

  // Existing indexes
  @@index([workspaceId, statusId])
  @@index([workspaceId, dueAt])
  @@index([workspaceId, completedAt])
  @@index([workspaceId, completedAt, archivedAt])
  @@index([workspaceId, todayPinDate])
  @@index([workspaceId, projectId])
  @@index([workspaceId, goalId])
  @@index([projectId])
  @@index([goalId])
  @@index([companyId])
  @@index([objectiveId])
  // Performance optimization indexes (2026-03-07)
  @@index([workspaceId, archivedAt]) // Board queries: WHERE workspaceId AND archivedAt IS NULL
  @@index([workspaceId, archivedAt, createdAt]) // Task list with sorting
  @@index([workspaceId, archivedAt, statusId]) // Board with status filtering
  @@index([workspaceId, todayPinDate, todayOrder]) // Dashboard today view with ordering
  @@index([assigneeId]) // User task queries
  @@index([botAssignee]) // Bot task queries (doug, harvey)
  @@index([createdAt]) // General sorting
  @@index([updatedAt]) // General sorting
  @@index([archivedAt]) // Archived task filtering
  // Objective progress calculation indexes (2026-03-09)
  @@index([objectiveId, completedAt, archivedAt]) // Direct objective tasks for progress
  @@index([projectId, completedAt, archivedAt]) // Project tasks for progress
  // Weekly planner indexes (2026-03-15)
  @@index([workspaceId, plannedDate]) // Weekly planner queries
  @@index([workspaceId, plannedDate, archivedAt]) // Active planned tasks
  // Multi-agent operating system indexes (2026-03-31)
  @@index([ownerAgent]) // Agent queue queries
  @@index([workspaceId, ownerAgent, archivedAt]) // Agent queue filtered by workspace
  @@index([decisionNeeded]) // Decision inbox
  @@index([waitingOn]) // Waiting-on-Ben view
  @@index([taskType]) // Task type filtering
}

// ==================== TAGS ====================

model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String   @db.Text
  name        String
  color       String?
  createdAt   DateTime @default(now()) @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

// ==================== INBOX (NEW - Phase 1) ====================

model InboxItem {
  id        String    @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String  @db.Text
  createdBy String    @db.Uuid
  
  // Capture data
  sourceType  String  // text, voice, ai_generated, import, email
  rawText     String
  transcript  String? // For voice captures
  cleanedText String? // AI-enhanced version
  
  // Optional enrichment
  assigneeId String?   @db.Uuid
  projectId  String?   @db.Text
  dueDate    DateTime? @db.Timestamptz()
  priority   Int?
  
  // Processing state
  status String @default("unprocessed") // unprocessed, processed, converted, completed, archived
  
  // AI fields
  aiProcessed Boolean @default(false)
  aiSummary   String?
  aiSuggestions Json? // Suggested: project, assignee, due date, split tasks
  
  // Conversion tracking
  convertedTaskIds String[] // Array of task IDs if split into multiple
  
  // Metadata
  metadata    Json?
  capturedAt  DateTime  @default(now()) @db.Timestamptz()
  processedAt DateTime? @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  
  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  @@index([workspaceId, status])
  @@index([createdBy])
  @@index([capturedAt])
}

model TaskTag {
  id     String @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  taskId String @db.Text
  tagId  String @db.Text

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

// ==================== PROJECTS (ENHANCED) ====================

model Project {
  id          String    @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String    @db.Text
  name        String
  goalId      String?   @db.Text
  defaultView String    @default("list")
  archivedAt  DateTime? @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()

  // NEW FIELDS
  companyId   String? @db.Text
  objectiveId String? @db.Text
  description String? @db.Text
  timeline    Json?
  priority    Int?
  owner       String? @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  // NEW RELATIONS
  company        Space?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  objective      Objective?      @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  documents      Document[]
  notes          Note[]
  memories       AIMemory[]
  files          File[]
  repeatingTasks RepeatingTask[]
  inboxItems     InboxItem[]

  // Existing indexes
  @@index([workspaceId])
  @@index([goalId])
  @@index([companyId])
  @@index([objectiveId])
  // Performance optimization indexes (2026-03-07)
  @@index([workspaceId, archivedAt]) // Active projects query
  @@index([createdAt]) // Sorting by creation date
  @@index([archivedAt]) // Archived project filtering
  // Objective progress calculation indexes (2026-03-09)
  @@index([objectiveId, archivedAt]) // Active projects for objective progress
}

// ==================== GOALS (ENHANCED) ====================

model Goal {
  id              String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId     String   @db.Text
  name            String
  descriptionRich Json?
  metricType      String
  targetValue     Decimal
  currentValue    Decimal  @default(0)
  unit            String?
  startDate       DateTime @db.Date()
  endDate         DateTime @db.Date()
  status          String   @default("active")
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()
  createdBy       String   @db.Uuid

  // NEW FIELDS
  missionId  String? @db.Text
  companyIds Json?
  owner      String?

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks           Task[]
  progressEntries GoalProgressEntry[]
  activityLogs    ActivityLog[]

  // NEW RELATIONS
  mission    Mission?    @relation(fields: [missionId], references: [id], onDelete: SetNull)
  objectives Objective[]

  @@index([workspaceId])
  @@index([status])
  @@index([endDate])
  @@index([missionId])
}

model GoalProgressEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  goalId      String   @db.Text
  value       Decimal
  entryDate   DateTime @db.Date()
  note        String?
  createdBy   String   @db.Uuid
  authorAgent String?  @db.Text  // agent id if created by a bot
  authorType  String   @default("user") // "user" | "agent" | "system"
  createdAt   DateTime @default(now()) @db.Timestamptz()

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([entryDate])
}

// ==================== DOCUMENTS (NEW) ====================

model Document {
  id           String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId  String   @db.Text
  companyId    String?  @db.Text
  projectId    String?  @db.Text
  title        String
  documentType String
  contentRich  Json
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()
  createdBy    String   @db.Uuid
  authorName   String?  @db.Text  // display name: "Benjamin", "Doug", "Harvey", etc.
  archivedAt   DateTime? @db.Timestamptz()

  // Tagging system
  functionTags String[] // source | core-strategy | technical | security | ops | gtm | meta
  typeTags     String[] // brief | memo | research | spec | playbook | sop | interview | script
  stageTags    String[] // validation | mvp | pilot | launch-ready
  canonical    Boolean  @default(false)
  supersededBy String?  @db.Text // docId of the document that supersedes this one

  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company        Space?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  files          File[]
  versions       DocumentVersion[]
  knowledgeLinks AgentKnowledgeLink[]

  @@index([workspaceId])
  @@index([companyId])
  @@index([projectId])
  @@index([documentType])
  @@index([updatedAt])
}

model DocumentVersion {
  id                String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  documentId        String   @db.Text
  version           Int
  contentRich       Json
  createdAt         DateTime @default(now()) @db.Timestamptz()
  createdBy         String   @db.Text  // user UUID or agent id ("doug", "harvey", etc.)

  // Authorship
  authorName        String?  @db.Text  // display name: "Benjamin", "Doug", "Harvey", etc.
  authorAgent       String?  @db.Text  // agent id if created by an agent
  authorType        String   @default("user") // "user" | "agent" | "system"

  // Change log
  changeDescription String?  @db.Text  // one-line summary of what changed
  changeTags        String[]            // content | structure | tags | title | minor | major | fix | rewrite
  changeNotes       String?  @db.Text  // extended notes / reasoning (optional)

  // Snapshot metadata
  snapshotTitle     String?  @db.Text  // title at time of snapshot
  snapshotTags      Json?               // tag state at time of snapshot (functionTags, typeTags, stageTags)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([version])
  @@index([createdBy])
  @@index([authorAgent])
}

// ==================== NOTES (NEW) ====================

model Note {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId String   @db.Text
  title       String
  body        String   @db.Text
  summary     String?  @db.Text
  noteType    String   @default("general") // general, strategy, plan, meeting, briefing, ops, partnership
  author      String?  @db.Text
  authorAgent String?  @db.Text  // agent id if created by a bot: "doug" | "harvey" | "theo" | "casper"
  authorType  String   @default("user") // "user" | "agent" | "system"

  companyId   String?  @db.Text
  projectId   String?  @db.Text
  objectiveId String?  @db.Text
  taskId      String?  @db.Text

  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()
  createdBy   String   @db.Uuid

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company    Space?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  project    Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  objective  Objective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  task       Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([companyId])
  @@index([projectId])
  @@index([objectiveId])
  @@index([updatedAt])
}

// ==================== AI MEMORY (NEW) ====================

model AIMemory {
  id              String   @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  workspaceId     String   @db.Text
  companyId       String?  @db.Text
  projectId       String?  @db.Text
  objectiveId     String?  @db.Text
  taskId          String?  @db.Text
  memoryType      String
  title           String
  description     String   @db.Text
  confidenceScore Int
  source          String?
  createdBy       String?  @db.Text // "doug", "harvey", user UUID, or null
  authorAgent     String?  @db.Text // explicit agent: "harvey" | "theo" | "doug" | "casper"
  authorType      String   @default("user") // "user" | "agent" | "system"
  entryType       String?  @db.Text // "daily_wrap" | "progress" | "blocker" | "decision" | "handoff" | "note" | "routine"
  // Structured daily wrap fields
  completed       Json?    // array of completed items
  decisions       Json?    // array of decisions made
  blockers        Json?    // array of blockers discovered
  pending         Json?    // array of carry-over items
  tomorrowFirst   Json?    // array of next-day priorities
  // Timeline grouping + filtering
  date            String?  @db.Text  // "YYYY-MM-DD" — date of the memory entry for timeline grouping
  tags            String[] @default([])

  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
